# ── Local development ─────────────────────────────────────
# Copy this file to .env and fill in values

NODE_ENV=development
PORT=4000

# Prisma Postgres (pooled — from prisma.io dashboard)
DATABASE_URL="postgres://<user>:<password>@pooled.db.prisma.io:5432/postgres?sslmode=require"

# Direct (non-pooled) URL used by prisma migrate — use the same host with port 5432 if unsure
DIRECT_DATABASE_URL="postgres://<user>:<password>@direct.db.prisma.io:5432/postgres?sslmode=require"

# Redis (docker-compose locally; use rediss:// for Upstash/production TLS)
REDIS_URL="redis://localhost:6379"

# URL of the Next.js frontend (Vercel URL in production)
CLIENT_URL="http://localhost:3000"
