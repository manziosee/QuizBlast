# ── Local development ─────────────────────────────────────
# Copy this file to .env and fill in values

NODE_ENV=development
PORT=4000

# PostgreSQL (docker-compose locally, Fly Postgres in production)
DATABASE_URL="postgresql://quizblast:quizblast_secret@localhost:5432/quizblast_db"

# Redis (docker-compose locally, Fly Redis / Upstash in production)
REDIS_URL="redis://localhost:6379"

# URL of the Next.js frontend (Vercel URL in production)
CLIENT_URL="http://localhost:3000"

# ── Fly.io secrets (set with: fly secrets set KEY=value) ──
# fly secrets set DATABASE_URL="postgresql://..."
# fly secrets set REDIS_URL="redis://..."
# fly secrets set CLIENT_URL="https://your-app.vercel.app"
# fly secrets set NODE_ENV="production"
