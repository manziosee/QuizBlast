    "@types/swagger-ui-express": "^4.1.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "groq-sdk": "^1.2.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.11.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.14.0",
